# Required: get from https://developer.spotify.com/dashboard
# Create an app, enable PKCE, and add your redirect URI
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: override the auto-detected redirect URI
# Auto-detection uses: window.location.origin + vite base path
# Only needed if auto-detection doesn't work for your deployment
# VITE_REDIRECT_URI=https://username.github.io/podcast-tracker/
